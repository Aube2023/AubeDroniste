# Donnees runtime (DB, uploads, mail dev)
data/

# Bases de données SQLite (au cas ou)
*.db
*.db-journal
*.db-wal
*.db-shm

# Secrets dev (mots de passe locaux fallback)
.dev_passwords

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.env
.pytest_cache/

# IDE / OS
.vscode/
.idea/
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# Uploads (généré au runtime)
static/uploads/

# Logs
*.log
nohup.out

# Artefacts de build mobile (APK/AAB : ne JAMAIS commiter, ~40 Mo)
*.apk
*.aab
mobile/build/
mobile/.dart_tool/

# Doublons de synchronisation iCloud ("config 2.py", "fichier 2.dart", ...)
# iCloud cree des copies suffixees " N.ext" qu'il ne faut pas versionner.
*[ ][0-9].py
*[ ][0-9].dart
